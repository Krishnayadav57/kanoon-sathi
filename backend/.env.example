# Copy this file to .env and fill in real values. NEVER commit the real .env file.

# --- App ---
ENVIRONMENT=production
DEBUG=false

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# --- CORS ---
CORS_ORIGINS=["https://yourdomain.com"]

# --- Database ---
DATABASE_URL=postgresql+psycopg2://kanoon:kanoon@db:5432/kanoon_mitra

# --- AI (Google AI Studio / Gemini) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Real-time Voice Assistant (Gemini Live API) ---
GEMINI_LIVE_MODEL=models/gemini-live-2.5-flash-native-audio
FREE_PLAN_DAILY_VOICE_SECONDS=300

# --- Subscription ---
FREE_PLAN_DAILY_MESSAGES=10
PREMIUM_MONTHLY_PRICE_NPR=499

# --- eSewa (manual verification mode by default — no merchant API needed) ---
ESEWA_MODE=manual
ESEWA_RECEIVER_NUMBER=9807778833
ESEWA_RECEIVER_NAME=Ramkumar Yadav
# Only needed if you switch ESEWA_MODE to "api" with real merchant credentials:
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=

# --- Khalti (manual verification mode by default) ---
KHALTI_MODE=manual
KHALTI_RECEIVER_NUMBER=9807778833
KHALTI_RECEIVER_NAME=Krishna Kumar Yadav
# Only needed if you switch KHALTI_MODE to "api" with real merchant credentials:
KHALTI_PUBLIC_KEY=
KHALTI_SECRET_KEY=

# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys — rotate any key that has
# ever been pasted in chat, a doc, or committed to source control.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From https://dashboard.stripe.com/webhooks after creating an endpoint pointing
# at https://yourdomain.com/api/v1/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_NPR_TO_USD_CENTS=400

# --- File uploads ---
MAX_UPLOAD_MB=10
UPLOAD_DIR=./uploads
